# ILMU-GLM credentials (YTL AI Labs x Z.AI — the official UMHackathon 2026 endpoint)
# Get your key from https://console.ilmu.ai/
# The guidebook uses ANTHROPIC_AUTH_TOKEN for Claude Code — we accept either name.
ILMU_API_KEY=your_ilmu_api_key_here
ANTHROPIC_AUTH_TOKEN=your_ilmu_api_key_here

ILMU_BASE_URL=https://api.ilmu.ai/anthropic

# Model selection — COPY EXACT STRINGS FROM YOUR ILMU CONSOLE.
# These are best-guess defaults. If an API call fails with "model not found",
# check the console for the correct identifier.
GLM_MODEL_REASONING=glm-5.1
GLM_MODEL_CHEAP=glm-4.7

# Optional — used by weather client and synthetic data
WEATHER_API_BASE=https://api.open-meteo.com/v1
DEFAULT_LAT=3.1390
DEFAULT_LON=101.6869
DEFAULT_CITY=Kuala Lumpur

# App settings
ENV=development
LOG_LEVEL=INFO
